# Copy this file to server/.env and fill in your key.

# Used by the Discover panel for AI taglines, hook variants, post copy and
# brand-fit scoring via Claude. Optional — without it those features are
# disabled and everything else still works.
ANTHROPIC_API_KEY=

# Port the API server listens on (default 8081).
#PORT=8081

# Set to 1 for verbose logs (ffmpeg filter graphs, yt-dlp commands, etc.).
#DEBUG=1
